# Railway provides DATABASE_URL automatically when you add a Postgres plugin
DATABASE_URL=postgres://user:password@localhost:5432/scamguard

PORT=3000

# Upstream scam-intel APIs (server-side only, never shipped to the extension)
URLSCAN_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# Cache TTL for domain check results, in hours
DOMAIN_CACHE_TTL_HOURS=24

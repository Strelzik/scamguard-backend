# Railway provides DATABASE_URL automatically when you add a Postgres plugin
DATABASE_URL=postgres://user:password@localhost:5432/scamguard

PORT=3000

# Upstream scam-intel APIs (server-side only, never shipped to the extension)
URLSCAN_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# Cache TTL for domain check results, in hours
DOMAIN_CACHE_TTL_HOURS=24

# --- Anti-abuse thresholds (all optional; defaults shown) ---
# Production should run DIFFERENT values than these public defaults, set as
# deployment env vars and treated as secrets. See lib/config.js.
# FREE_DAILY_CAP=50
# IP_LIMIT_PER_15MIN=300
# IP_REPORT_POSTS_PER_HOUR=20
# CREDIT_CORROBORATION_THRESHOLD=3
# CREDIT_TENURE_DAYS=7
# CREDIT_MIN_SPREAD_HOURS=24
# CREDIT_MAX_PER_30_DAYS=4
# COMMUNITY_TENURE_DAYS=7
# COMMUNITY_SCAM_MIN_VOTES=5
# COMMUNITY_SCAM_MIN_RATIO=0.8
# COMMUNITY_MIN_SPREAD_HOURS=24
